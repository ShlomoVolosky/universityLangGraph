# LLM provider — set at least one; Anthropic is preferred when both are present.

# Anthropic (preferred)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (fallback)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Database path (default: db/university.db)
DB_PATH=db/university.db

# Max LLM retry attempts (default: 3)
MAX_ATTEMPTS=3

# LangSmith tracing (set to true to enable)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=university-qa-dev
LANGSMITH_ENDPOINT=
