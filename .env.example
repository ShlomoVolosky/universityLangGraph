# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override default model
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional — database path (default: db/university.db)
DB_PATH=db/university.db

# Optional — max LLM retry attempts (default: 3)
MAX_ATTEMPTS=3

# LangSmith tracing (set to true to enable)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=university-qa-dev
